# ==========================================
# CONFIGURACIÓN DEL MODPACK - CEMELE
# ==========================================

# Nombre del modpack (aparece en el launcher)
MODPACK_NAME=Mi Modpack NeoForge

# Versión de Minecraft
MINECRAFT_VERSION=1.20.6

# Versión de NeoForge (sin prefijo de MC)
NEOFORGE_VERSION=20.6.139

# Versión de Java a instalar (Adoptium/Eclipse Temurin)
JAVA_VERSION=17.0.9+9

# RAM del juego
RAM_MIN=2G
RAM_MAX=4G

# ==========================================
# SERVIDOR DE ARCHIVOS (¡CAMBIA ESTO!)
# ==========================================

# URL base donde están todos los archivos del modpack
SERVER_BASE_URL=https://tu-servidor.com/modpack

# URL al archivo mods.json (lista de mods)
SERVER_MODS_LIST_URL=https://tu-servidor.com/modpack/mods.json

# URL al icono del modpack (opcional)
SERVER_ICON_URL=https://tu-servidor.com/modpack/icon.png

# ==========================================
# AVANZADO - URLs DE DESCARGA DIRECTA
# ==========================================

# Forzar URL específica del installer de NeoForge (opcional)
# Si está vacío, se calcula automáticamente desde el maven
NEOFORGE_INSTALLER_URL=

# Forzar URL específica de Java (opcional)
# Si está vacío, usa Adoptium automáticamente
JAVA_DOWNLOAD_URL=