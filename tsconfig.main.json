{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "CommonJS",
    "target": "ES2020",
    "jsx": "preserve",
    "rootDir": "./src",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/main/**/*", "src/shared/**/*"],
  "exclude": ["src/renderer/**/*"]
}